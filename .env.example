# Copy this file to `.env.local` to enable the phone number on the resume
# and cover letter pages during `npm run dev`. The production build
# (`npm run build` / `npm run generate`) does not read `.env.local`, so the
# deployed site stays phone-free.
#
# Format is free-form; the `tel:` link strips non-digits and prepends +1.
NUXT_PUBLIC_PHONE=
